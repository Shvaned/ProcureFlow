{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:8000/api/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "http://localhost:8000"
  },
  "github": {
    "silent": true
  }
}
